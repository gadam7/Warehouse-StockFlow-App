# Spring profile
ACTIVE_PROFILE=dev

# Backend port (container and host)
CONTAINER_PORT=8080

# MySQL (host port exposed on your machine)
MYSQL_PORT=3308
MYSQL_DATABASE=warehouse_stockflow
MYSQL_USERNAME=stockflow_user
MYSQL_PASSWORD=stockflow_pass
MYSQL_ROOT_PASSWORD=root_pass

# JWT
JWT_SECRET=change-me-to-a-long-random-string

# Frontend URL used by backend (CORS, links, etc.)
UI_APP_URL=http://localhost:4200

# Mail (set dummy values if not used in dev)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=dummy
MAIL_PASSWORD=dummy